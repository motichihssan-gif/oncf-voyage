{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.3"
        },
        {
            "src": "api/debug.php",
            "use": "vercel-php@0.7.3"
        },
        {
            "src": "api/check-config.php",
            "use": "vercel-php@0.7.3"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/check",
            "dest": "/api/check-config.php"
        },
        {
            "src": "/debug",
            "dest": "/api/debug.php"
        },
        {
            "src": "/(css|js|images)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/([^/]+\\.(png|jpg|jpeg|gif|ico|svg|css|js))",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_URL": "https://oncf-voyage.vercel.app",
        "VIEW_COMPILED_PATH": "/tmp",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr"
    }
}
